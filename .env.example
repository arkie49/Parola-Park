# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Email (SMTP) settings for booking confirmations
# Example (Gmail):
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="465"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-app-password"
# MAIL_FROM="Parola Park <your@gmail.com>"
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM=""

# Resend (recommended for production)
# If RESEND_API_KEY is set, the Vercel `/api/send-booking-confirmation` route will use Resend.
# MAIL_FROM must be a verified sender in Resend (or use `onboarding@resend.dev` for testing).
RESEND_API_KEY=""
RESEND_FROM=""
MAIL_REPLY_TO=""

# Local email server port
PORT="3001"
